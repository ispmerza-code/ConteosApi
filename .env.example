# =============================================================================
# BACKEND — Variables de entorno (local y Vercel)
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a Git.
# =============================================================================

# --- Aiven MySQL ---
# Formato: mysql+pymysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Ejemplo Aiven:
# DATABASE_URL=mysql+pymysql://avnadmin:TU_PASSWORD@mysql-abc123.a.aivencloud.com:12345/siniestros_scisp
#
# Si la contraseña tiene caracteres especiales (@, #, /, etc.), codifícalos en URL:
#   @ → %40   # → %23   / → %2F   : → %3A
DATABASE_URL=mysql+pymysql://USUARIO:CONTRASEÑA@HOST.a.aivencloud.com:PUERTO/siniestros_scisp

# TLS con Aiven en entornos serverless (Vercel). Dejar en false salvo que configures CA bundle.
DB_SSL_VERIFY=false

# --- Autenticación JWT ---
# Genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_secreta_muy_segura_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS ---
# En producción: URL exacta del frontend en Vercel (sin barra final).
# Puedes poner varias separadas por coma.
# Ejemplo: https://conteos-frontend.vercel.app,http://localhost:3000
#
# Para el primer despliegue (antes de conocer la URL del frontend), usa temporalmente:
# ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=http://localhost:3000

# --- App ---
PROJECT_NAME=API Conteos SCISP
PROJECT_VERSION=1.0.0
LOG_LEVEL=info
